{
  "name": "zario",
  "version": "0.8.5",
  "description": "Fast and simple logging library for TypeScript.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js",
      "require": "./dist/logger.cjs"
    },
    "./core/*": {
      "types": "./dist/core/*.d.ts",
      "import": "./dist/core/*.js",
      "require": "./dist/core/*.cjs"
    },
    "./transports/*": {
      "types": "./dist/transports/*.d.ts",
      "import": "./dist/transports/*.js",
      "require": "./dist/transports/*.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "lint": "eslint src benchmarks --ext .ts --max-warnings=0",
    "check-benchmark-schema": "node scripts/check-benchmark-schema.js",
    "check-bundle-size": "bun run scripts/check-bundle-size.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dev-Dami/zario.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Dev-Dami"
  },
  "keywords": [
    "logging",
    "logger",
    "console",
    "terminal",
    "typescript",
    "nodejs",
    "structured-logging",
    "json",
    "circuit-breaker",
    "retry",
    "dead-letter-queue",
    "async-logging",
    "enterprise",
    "resilience",
    "performance",
    "microservices",
    "error-handling",
    "zero-dependencies"
  ],
  "author": "Dev-dami",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "bugs": {
    "url": "https://github.com/Dev-Dami/zario/issues"
  },
  "homepage": "https://github.com/Dev-Dami/zario#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/parser": "^8.46.4",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ]
}
